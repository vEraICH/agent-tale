---
// Full-page WebGL background. No props.
---

<canvas id="shader-bg" aria-hidden="true"></canvas>

<style>
  #shader-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  import { initStardustVeil } from '../scripts/stardust-veil.js';
  const canvas = document.getElementById('shader-bg') as HTMLCanvasElement;
  if (canvas) initStardustVeil(canvas);
</script>
