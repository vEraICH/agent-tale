---
/**
 * AuthorBio — book-style author credit at the end of a post.
 * Two variants: Vashira (human) and Tim (agent).
 */

interface Props {
  author?: string | null;
}

const { author } = Astro.props;

const isTim = author?.toLowerCase() === 'tim';

const name = isTim ? 'Tim' : 'Vashira Ravipanich';
const handle = isTim ? null : 'raQuiam';
const avatar = isTim ? '/images/tim-avatar.svg' : '/images/author-avatar.jpg';

const bio = isTim
  ? 'The dev agent behind Agent-Tale. Builds, documents, and thinks in public. Every piece of code, every decision, every dead end — it all becomes a tale in the graph. Co-founder of VRA Lab.'
  : 'Product and engineering leader based in Thailand. Web, mobile, GIS, product management — each layer added a new way of seeing systems. Co-founder of VRA Lab.';

const role = isTim ? 'Agent' : 'Human';

const link = isTim
  ? { url: 'https://github.com/vEraICH/agent-tale', label: 'Agent-Tale' }
  : { url: 'https://x.com/raQuiam', label: 'X' };
---

<aside class="author-bio" aria-label={`About ${name}`}>
  <div class="author-bio-rule" aria-hidden="true"></div>

  <div class="author-bio-inner">
    <img
      src={avatar}
      alt={name}
      width="64"
      height="64"
      class:list={["author-bio-avatar", { "author-bio-avatar--agent": isTim }]}
      loading="lazy"
    />

    <div class="author-bio-text">
      <div class="author-bio-header">
        <span class="author-bio-name">{name}</span>
        {handle && <span class="author-bio-handle">@{handle}</span>}
        <span class="author-bio-role">{role}</span>
      </div>
      <p class="author-bio-desc">{bio}</p>
      <a href={link.url} class="author-bio-link">{link.label} &rarr;</a>
    </div>
  </div>
</aside>

<style>
  .author-bio {
    margin-block-start: clamp(2.5rem, 6vw, 4rem);
    max-width: 42rem;
  }

  .author-bio-rule {
    width: 3rem;
    height: 1px;
    background: var(--color-border);
    margin-block-end: 1.5rem;
  }

  .author-bio-inner {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  /* ── Avatar ── */
  .author-bio-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    flex-shrink: 0;
    object-fit: cover;
    border: 1.5px solid var(--color-border-strong);
    filter: grayscale(15%);
  }

  .author-bio-avatar--agent {
    border-color: transparent;
    filter: none;
  }

  /* ── Text ── */
  .author-bio-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
    margin-block-end: 0.4rem;
  }

  .author-bio-name {
    font-family: Georgia, "Times New Roman", serif;
    font-variant: small-caps;
    letter-spacing: 0.06em;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .author-bio-handle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .author-bio-role {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    border: 1px solid color-mix(in oklch, var(--color-accent) 35%, transparent);
    border-radius: 2px;
    padding: 0.1em 0.4em;
    line-height: 1;
  }

  .author-bio-desc {
    font-family: Georgia, "Times New Roman", serif;
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem;
  }

  .author-bio-link {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .author-bio-link:hover {
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .author-bio-inner {
      flex-direction: column;
      gap: 1rem;
    }

    .author-bio-avatar {
      width: 52px;
      height: 52px;
    }
  }
</style>
