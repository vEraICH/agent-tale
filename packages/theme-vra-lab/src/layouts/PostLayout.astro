---
import BaseLayout from './BaseLayout.astro';
import TagList from '@agent-tale/theme-default/components/TagList.astro';
import BacklinksPanel from '@agent-tale/theme-default/components/BacklinksPanel.astro';
import AuthorBio from '../components/AuthorBio.astro';

interface BacklinkRef {
  slug: string;
  title: string;
}

interface PostNavLink {
  slug: string;
  title: string;
}

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  date: string;
  description?: string;
  tags?: string[];
  agent?: string | null;
  author?: string | null;
  confidence?: number | null;
  minutesRead?: number | null;
  backlinks?: BacklinkRef[];
  ogImage?: string;
  postNav?: { prev: PostNavLink | null; next: PostNavLink | null };
  headings?: Heading[];
  slug?: string;
}

const {
  title,
  date,
  description,
  tags = [],
  agent,
  author,
  confidence,
  minutesRead,
  backlinks = [],
  ogImage,
  postNav,
  headings = [],
  slug,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showToc = tocHeadings.length >= 3;

const isoDate = new Date(date).toISOString();
const authorName = agent ?? author ?? 'VRA Lab';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  ...(description && { description }),
  datePublished: isoDate,
  author: {
    '@type': agent ? 'Thing' : 'Person',
    name: agent === 'tim' ? 'Tim' : (author === 'tim' ? 'Tim' : (authorName === 'VRA Lab' ? 'Vashira Ravipanich' : authorName)),
  },
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
  ...(minutesRead && { timeRequired: `PT${minutesRead}M` }),
  ...(ogImage && { image: ogImage }),
});

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const confidenceLabel = confidence != null
  ? `${Math.round(confidence * 100)}% confidence`
  : null;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <script slot="head" type="application/ld+json" set:html={jsonLd} />
  <div class="reading-progress" aria-hidden="true"></div>
  <div class={`post-layout ${showToc ? 'post-layout--has-toc' : ''}`}>
    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <time datetime={date}>{formattedDate}</time>
          {slug && (
            <>
              <span class="post-meta-sep" aria-hidden="true">&middot;</span>
              <a href={`/posts/${slug}.md`} class="post-llm-link" title="View as Markdown (LLM-friendly)">md</a>
            </>
          )}
          {minutesRead && (
            <>
              <span class="post-meta-sep" aria-hidden="true">&middot;</span>
              <span>{minutesRead} min read</span>
            </>
          )}
          {agent && (
            <>
              <span class="post-meta-sep" aria-hidden="true">&middot;</span>
              <span class="post-agent">{agent}</span>
            </>
          )}
          {confidenceLabel && (
            <>
              <span class="post-meta-sep" aria-hidden="true">&middot;</span>
              <span class="post-confidence">{confidenceLabel}</span>
            </>
          )}
        </div>
      </header>

      <div class="prose post-content">
        <slot />
      </div>

      <footer class="post-footer">
        <TagList tags={tags} variant="pill" />
        <AuthorBio author={author} />
      </footer>

      {postNav && (postNav.prev || postNav.next) && (
        <nav class={`post-nav ${postNav.prev && postNav.next ? 'post-nav--both' : ''}`} aria-label="Post navigation">
          {postNav.prev && (
            <a href={`/posts/${postNav.prev.slug}`} class="post-nav-link post-nav-prev">
              <span class="post-nav-label">Older</span>
              <span class="post-nav-title">{postNav.prev.title}</span>
            </a>
          )}
          {postNav.next && (
            <a href={`/posts/${postNav.next.slug}`} class="post-nav-link post-nav-next">
              <span class="post-nav-label">Newer</span>
              <span class="post-nav-title">{postNav.next.title}</span>
            </a>
          )}
        </nav>
      )}

      <BacklinksPanel backlinks={backlinks} />
    </article>

    {showToc && (
      <aside class="toc-sidebar" aria-label="Table of contents">
        <nav class="toc-sticky">
          <p class="toc-title">On this page</p>
          <ol class="toc-list">
            {tocHeadings.map((h) => (
              <li class={h.depth === 3 ? 'toc-item toc-item--nested' : 'toc-item'}>
                <a href={`#${h.slug}`} class="toc-link" data-toc-slug={h.slug}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    )}
  </div>

  <style>
    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      width: 0%;
      height: 2px;
      background: var(--color-accent, oklch(0.655 0.135 32));
      z-index: 100;
      transition: width 50ms linear;
      pointer-events: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .reading-progress { transition: none; }
    }

    /* ── Post layout with optional TOC sidebar ── */
    .post-layout {
      max-width: 60rem;
      margin-inline: auto;
    }

    .post {
      min-width: 0;
    }

    .post-header {
      margin-block-end: clamp(2rem, 5vw, 3rem);
    }

    .post-title {
      font-size: clamp(1.875rem, 1.5rem + 1.5vw, 2.75rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-block-end: 1rem;
    }

    .post-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.25rem;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      color: var(--color-text-tertiary);
      letter-spacing: 0.01em;
    }

    .post-meta-sep {
      margin-inline: 0.3rem;
      color: var(--color-text-tertiary);
      opacity: 0.6;
    }

    .post-agent {
      font-weight: 600;
      color: var(--color-text-secondary);
    }

    .post-confidence {
      font-variant-numeric: tabular-nums;
    }

    .post-llm-link {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--color-text-tertiary);
      text-decoration: none;
      border: 1px solid var(--color-border);
      border-radius: 3px;
      padding: 0.1em 0.35em;
      transition: color 0.15s ease, border-color 0.15s ease;
    }

    .post-llm-link:hover {
      color: var(--color-accent);
      border-color: var(--color-accent);
    }

    /* ── Table of contents — sidebar ── */
    .toc-sidebar {
      display: none;
    }

    @media (min-width: 1200px) {
      .post-layout--has-toc {
        display: grid;
        grid-template-columns: 1fr 200px;
        gap: 3rem;
        max-width: 68rem;
      }

      .toc-sidebar {
        display: block;
      }

      .toc-sticky {
        position: sticky;
        top: 6rem;
        max-height: calc(100vh - 8rem);
        overflow-y: auto;
        scrollbar-width: none;
      }

      .toc-sticky::-webkit-scrollbar {
        display: none;
      }
    }

    .toc-title {
      font-family: var(--font-heading);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-tertiary);
      margin: 0 0 0.75rem;
    }

    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      border-inline-start: 1px solid var(--color-border);
    }

    .toc-item {
      margin: 0;
    }

    .toc-link {
      display: block;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 400;
      color: var(--color-text-tertiary);
      text-decoration: none;
      padding: 0.3rem 0 0.3rem 0.75rem;
      border-inline-start: 2px solid transparent;
      margin-inline-start: -1px;
      transition: color 0.15s ease, border-color 0.15s ease;
      line-height: 1.4;
    }

    .toc-link:hover {
      color: var(--color-text-secondary);
    }

    .toc-link[data-active="true"] {
      color: var(--color-text);
      border-inline-start-color: var(--color-accent);
      font-weight: 500;
    }

    .toc-item--nested .toc-link {
      padding-inline-start: 1.5rem;
      font-size: 0.8rem;
    }

    .post-content {
      margin-block-end: 2.5rem;
    }

    .post-footer {
      padding-block-start: 1.5rem;
      border-block-start: 1px solid var(--color-border);
    }

    /* ── Post navigation ── */
    .post-nav {
      margin-block-start: 2.5rem;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      overflow: hidden;
    }

    .post-nav--both {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background-color: var(--color-border);
    }

    .post-nav-link {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1.25rem 1.5rem;
      background-color: var(--color-bg);
      text-decoration: none;
      transition: background-color 0.15s ease;
    }

    .post-nav-link:hover {
      background-color: var(--color-surface);
    }

    .post-nav-next {
      text-align: end;
    }

    .post-nav-label {
      font-family: var(--font-heading);
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-text-tertiary);
    }

    .post-nav-title {
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--color-text);
      line-height: 1.3;
    }

    .post-nav-link:hover .post-nav-title {
      color: var(--color-accent);
    }

    @media (max-width: 640px) {
      .post-nav {
        grid-template-columns: 1fr;
      }

      .post-nav-next {
        text-align: start;
      }
    }
  </style>

  <style is:global>
    /* ── Copy code button ── */
    .code-block-wrapper {
      position: relative;
    }

    .copy-code-btn {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.25rem 0.5rem;
      font-family: var(--font-heading);
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      color: var(--color-text-tertiary);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.15s ease, color 0.15s ease, border-color 0.15s ease;
      z-index: 1;
    }

    .code-block-wrapper:hover .copy-code-btn {
      opacity: 1;
    }

    .copy-code-btn:hover {
      color: var(--color-text-secondary);
      border-color: var(--color-border-strong);
    }

    .copy-code-btn[data-copied="true"] {
      color: var(--color-accent);
      border-color: var(--color-accent);
      opacity: 1;
    }

    .copy-code-btn svg {
      width: 12px;
      height: 12px;
    }
  </style>

  <script>
    // Scroll spy for TOC
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link[data-toc-slug]');
    if (tocLinks.length > 0) {
      const OFFSET = 100; // px from top to consider "active"

      function updateActiveToc() {
        let activeSlug = '';
        for (const link of tocLinks) {
          const slug = link.getAttribute('data-toc-slug')!;
          const heading = document.getElementById(slug);
          if (heading) {
            const top = heading.getBoundingClientRect().top;
            if (top <= OFFSET) {
              activeSlug = slug;
            }
          }
        }
        for (const link of tocLinks) {
          const isActive = link.getAttribute('data-toc-slug') === activeSlug;
          link.setAttribute('data-active', String(isActive));
        }
      }

      window.addEventListener('scroll', updateActiveToc, { passive: true });
      updateActiveToc();
    }
  </script>

  <script>
    // Reading progress bar
    const progressBar = document.querySelector('.reading-progress') as HTMLElement | null;
    const article = document.querySelector('.post-content') as HTMLElement | null;
    if (progressBar && article) {
      // Sync color with computed accent (fixes CSS load order issues)
      function syncColor() {
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim();
        if (accent) progressBar!.style.background = accent;
      }
      syncColor();
      const observer = new MutationObserver(syncColor);
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      function updateProgress() {
        const rect = article!.getBoundingClientRect();
        const start = rect.top + window.scrollY;
        const end = start + rect.height - window.innerHeight;
        const progress = Math.min(1, Math.max(0, (window.scrollY - start) / (end - start)));
        progressBar!.style.width = `${progress * 100}%`;
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }
  </script>

  <script>
    const COPY_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
    const CHECK_ICON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;

    document.querySelectorAll('.prose pre').forEach((pre) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper';
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      const btn = document.createElement('button');
      btn.className = 'copy-code-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;
      wrapper.appendChild(btn);

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        const text = code ? code.textContent ?? '' : pre.textContent ?? '';
        await navigator.clipboard.writeText(text);

        btn.innerHTML = `${CHECK_ICON}<span>Copied</span>`;
        btn.setAttribute('data-copied', 'true');

        setTimeout(() => {
          btn.innerHTML = `${COPY_ICON}<span>Copy</span>`;
          btn.removeAttribute('data-copied');
        }, 2000);
      });
    });
  </script>

  <!-- ── Wikilink hover preview (vra-9) ── -->
  <div id="wikilink-popover" role="tooltip" aria-live="polite" hidden>
    <div class="wp-header">
      <div class="wp-tags" id="wp-tags"></div>
      <button class="wp-close" id="wp-close" aria-label="Close preview">
        <svg class="wp-pin-icon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M16 3a1 1 0 0 1 .707.293l4 4A1 1 0 0 1 20 9h-1v1a3 3 0 0 1-1.5 2.598l-.866.5L15 15.732V19a1 1 0 0 1-.553.894l-4 2A1 1 0 0 1 9 21v-5.268l-1.634-2.83-.866-.5A3 3 0 0 1 5 10V9H4a1 1 0 0 1-.707-1.707l4-4A1 1 0 0 1 8 3h8z"/>
        </svg>
        ×
      </button>
    </div>
    <div class="wp-title" id="wp-title"></div>
    <div class="wp-excerpt" id="wp-excerpt"></div>
    <div class="wp-footer">
      <span class="wp-connections" id="wp-connections"></span>
      <a class="wp-open-link" id="wp-open-link" href="#">Open post →</a>
      <span class="wp-hint">click to pin</span>
    </div>
  </div>

  <style is:global>
    #wikilink-popover {
      position: fixed;
      z-index: 200;
      width: 280px;
      background: var(--color-surface);
      border: 1px solid var(--color-border-strong);
      border-radius: 8px;
      padding: 1rem 1.1rem;
      box-shadow: 0 8px 32px oklch(0 0 0 / 0.45), 0 2px 8px oklch(0 0 0 / 0.25);
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 0.15s ease, transform 0.15s ease;
      pointer-events: none;
    }

    #wikilink-popover:not([hidden]) {
      display: block;
    }

    #wikilink-popover.wp-visible {
      opacity: 1;
      transform: translateY(0);
    }

    #wikilink-popover.wp-pinned {
      pointer-events: all;
      border-color: color-mix(in oklch, var(--color-accent) 55%, transparent);
    }

    .wp-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.5rem;
      margin-block-end: 0.55rem;
    }

    .wp-tags {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
    }

    .wp-tag {
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--color-accent);
      background: color-mix(in oklch, var(--color-accent) 12%, transparent);
      border-radius: 3px;
      padding: 0.1em 0.5em;
    }

    .wp-close {
      flex-shrink: 0;
      display: none;
      align-items: center;
      gap: 0.3rem;
      background: none;
      border: none;
      color: var(--color-text-tertiary);
      cursor: pointer;
      font-size: 0.85rem;
      line-height: 1;
      padding: 0.15em 0.35em;
      border-radius: 3px;
    }

    .wp-close:hover {
      color: var(--color-text);
      background: var(--color-border);
    }

    #wikilink-popover.wp-pinned .wp-close {
      display: flex;
    }

    .wp-pin-icon {
      color: var(--color-accent);
    }

    .wp-title {
      font-size: 0.92rem;
      font-weight: 700;
      color: var(--color-text);
      letter-spacing: -0.01em;
      line-height: 1.3;
      margin-block-end: 0.45rem;
    }

    .wp-excerpt {
      font-size: 0.8rem;
      color: var(--color-text-tertiary);
      line-height: 1.6;
    }

    .wp-footer {
      margin-block-start: 0.75rem;
      padding-block-start: 0.65rem;
      border-block-start: 1px solid var(--color-border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .wp-connections {
      font-size: 0.7rem;
      color: var(--color-text-tertiary);
      font-variant-numeric: tabular-nums;
    }

    .wp-open-link {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--color-accent);
      text-decoration: none;
      display: none;
    }

    .wp-open-link:hover {
      text-decoration: underline;
    }

    #wikilink-popover.wp-pinned .wp-open-link { display: inline; }
    #wikilink-popover.wp-pinned .wp-hint { display: none; }

    .wp-hint {
      font-size: 0.7rem;
      color: var(--color-text-tertiary);
    }
  </style>

  <script>
    const popover    = document.getElementById('wikilink-popover')!;
    const wpTitle    = document.getElementById('wp-title')!;
    const wpExcerpt  = document.getElementById('wp-excerpt')!;
    const wpTags     = document.getElementById('wp-tags')!;
    const wpConns    = document.getElementById('wp-connections')!;
    const wpOpenLink = document.getElementById('wp-open-link') as HTMLAnchorElement;
    const wpClose    = document.getElementById('wp-close')!;

    let hideTimer: ReturnType<typeof setTimeout> | null = null;
    let pinned = false;
    const cache = new Map<string, { title: string; excerpt: string; tags: string[]; connections: number }>();

    function slugFromHref(href: string): string {
      // e.g. /posts/my-slug → my-slug
      return href.split('/').filter(Boolean).pop() ?? '';
    }

    function position(link: HTMLElement) {
      const rect = link.getBoundingClientRect();
      const pad = 12;
      const pWidth = 280;
      const pHeight = popover.offsetHeight || 180;

      let left = rect.left + rect.width / 2 - pWidth / 2;
      let top  = rect.bottom + pad;

      if (top + pHeight > window.innerHeight - 16) top = rect.top - pHeight - pad;
      left = Math.max(16, Math.min(left, window.innerWidth - pWidth - 16));

      popover.style.left = `${left}px`;
      popover.style.top  = `${top}px`;
    }

    function populate(data: typeof cache extends Map<string, infer V> ? V : never, href: string) {
      wpTitle.textContent   = data.title;
      wpExcerpt.textContent = data.excerpt;
      wpConns.textContent   = `${data.connections} connection${data.connections !== 1 ? 's' : ''}`;
      wpTags.innerHTML      = data.tags.map(t => `<span class="wp-tag">${t}</span>`).join('');
      wpOpenLink.href       = href;
    }

    async function fetchPreview(slug: string) {
      if (cache.has(slug)) return cache.get(slug)!;
      try {
        const res = await fetch(`/api/preview/${slug}`);
        if (!res.ok) return null;
        const data = await res.json();
        cache.set(slug, data);
        return data;
      } catch { return null; }
    }

    async function showPreview(link: HTMLAnchorElement) {
      if (pinned) return;
      clearTimeout(hideTimer!);

      const slug = slugFromHref(link.href);
      if (!slug) return;

      const data = await fetchPreview(slug);
      if (!data || pinned) return; // may have changed while awaiting

      populate(data, link.href);
      popover.removeAttribute('hidden');
      position(link);
      requestAnimationFrame(() => popover.classList.add('wp-visible'));
    }

    function hidePreview() {
      if (pinned) return;
      hideTimer = setTimeout(() => {
        popover.classList.remove('wp-visible');
        setTimeout(() => { if (!pinned) popover.setAttribute('hidden', ''); }, 150);
      }, 100);
    }

    async function pinPreview(link: HTMLAnchorElement) {
      clearTimeout(hideTimer!);

      const slug = slugFromHref(link.href);
      if (!slug) return;

      const data = await fetchPreview(slug);
      if (!data) return;

      populate(data, link.href);
      popover.removeAttribute('hidden');
      position(link);
      pinned = true;
      popover.classList.add('wp-visible', 'wp-pinned');
    }

    function unpin() {
      pinned = false;
      popover.classList.remove('wp-visible', 'wp-pinned');
      setTimeout(() => popover.setAttribute('hidden', ''), 150);
    }

    wpClose.addEventListener('click', unpin);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && pinned) unpin();
    });

    document.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (pinned && !popover.contains(t) && !t.closest('a.wikilink')) unpin();
    });

    document.querySelectorAll<HTMLAnchorElement>('.post-content a.wikilink:not(.wikilink-broken)').forEach(link => {
      link.addEventListener('mouseenter', () => showPreview(link));
      link.addEventListener('mouseleave', hidePreview);
      link.addEventListener('click', (e) => {
        e.preventDefault();
        if (pinned) { unpin(); return; }
        pinPreview(link);
      });
    });
  </script>
</BaseLayout>
