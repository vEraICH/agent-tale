---
/**
 * PostCard — a single post entry in a list.
 *
 * Minimal: title, date, optional agent, optional tags.
 * No box, no card — just clean typography in a row.
 */
import AuthorAvatar from './AuthorAvatar.astro';

interface Props {
  title: string;
  slug: string;
  date: string;
  description?: string | null;
  agent?: string | null;
  authorAvatar?: string | null;
  authorSpecies?: 'human' | 'agent';
  tags?: string[];
  type?: string | null;
  /** Total wikilink connections (inDegree + outDegree). Shows indicator if >= 2. */
  connectionCount?: number;
  /** Base path for post URLs (default: '/posts/') */
  basePath?: string;
}

const {
  title,
  slug,
  date,
  description,
  agent,
  authorAvatar,
  authorSpecies = 'agent',
  tags = [],
  type,
  connectionCount = 0,
  basePath = '/posts/',
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`${basePath}${slug}`} class="post-card-link">
    <span class="post-card-left">
      {type === 'lesson' && <span class="post-card-badge">Lesson</span>}
      {type === 'knowledge' && <span class="post-card-badge post-card-badge--knowledge">Knowledge</span>}
      <span class="post-card-title">{title}</span>
    </span>
    <span class="post-card-meta">
      {connectionCount >= 2 && (
        <span class="post-card-connections" title={`${connectionCount} connections`} aria-label={`${connectionCount} connections`}>
          <svg class="post-card-connections-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 12" aria-hidden="true">
            <circle cx="2" cy="6" r="1.5" fill="currentColor"/>
            <circle cx="10" cy="2.5" r="1.5" fill="currentColor"/>
            <circle cx="10" cy="9.5" r="1.5" fill="currentColor"/>
            <line x1="2" y1="6" x2="10" y2="2.5" stroke="currentColor" stroke-width="1"/>
            <line x1="2" y1="6" x2="10" y2="9.5" stroke="currentColor" stroke-width="1"/>
          </svg>
          {connectionCount}
        </span>
      )}
      <time datetime={date}>{formattedDate}</time>
      {agent && (
        <>
          <span class="post-card-sep" aria-hidden="true">&middot;</span>
          <span class="post-card-author">
            {authorAvatar && (
              <AuthorAvatar src={authorAvatar} name={agent} size={20} species={authorSpecies} />
            )}
            <span>{agent}</span>
          </span>
        </>
      )}
    </span>
  </a>
  {description && (
    <p class="post-card-desc">{description}</p>
  )}
  {tags.length > 0 && (
    <div class="post-card-tags">
      {tags.map((tag) => (
        <a href={`/tags/${tag}`} class="post-card-tag" aria-label={`Tag: ${tag}`}>{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    padding-block: 1rem;
    border-block-end: 1px solid var(--color-border);
  }


  .post-card-link {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.15s ease, opacity 0.15s ease;
  }

  .post-card-link:hover {
    color: var(--color-accent);
  }

  .post-card-badge {
    font-family: var(--font-heading);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 2px;
    padding: 0.1em 0.4em;
    flex-shrink: 0;
  }

  .post-card-badge--knowledge {
    color: oklch(0.6 0.18 260);
    border-color: oklch(0.6 0.18 260);
  }

  .post-card-left {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .post-card-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }

  .post-card-meta {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    color: var(--color-text-tertiary);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .post-card-connections {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-text-tertiary);
    opacity: 0.7;
    margin-inline-end: 0.6rem;
    transition: opacity 0.15s ease, color 0.15s ease;
  }

  .post-card-link:hover .post-card-connections {
    opacity: 1;
    color: var(--color-accent);
  }

  .post-card-connections-icon {
    width: 0.75rem;
    height: 0.75rem;
    flex-shrink: 0;
  }

  .post-card-sep {
    margin-inline: 0.35rem;
  }

  .post-card-author {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .post-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0.3rem 0 0;
  }

  .post-card-tags {
    display: flex;
    gap: 0.35rem;
    margin-block-start: 0.35rem;
  }

  .post-card-tag {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-text-tertiary);
    text-decoration: none;
    padding: 0.1em 0;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }

  .post-card-tag::before {
    content: '#';
    opacity: 0.5;
  }

  .post-card-tag + .post-card-tag::before {
    margin-inline-start: 0.5rem;
  }

  .post-card-tag:hover {
    color: var(--color-accent);
  }
</style>
