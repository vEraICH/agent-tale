---
/**
 * BacklinksPanel — shows incoming graph connections for a post.
 *
 * The graph made visible. Each backlink is a node that points here.
 */

interface BacklinkRef {
  slug: string;
  title: string;
}

interface Props {
  backlinks: BacklinkRef[];
  /** Base path for post URLs (default: '/posts/') */
  basePath?: string;
}

const { backlinks, basePath = '/posts/' } = Astro.props;
---

{backlinks.length > 0 && (
  <aside class="backlinks" aria-label="Backlinks">
    <h2 class="backlinks-title">Linked from</h2>
    <ul class="backlinks-list">
      {backlinks.map((link) => (
        <li>
          <a href={`${basePath}${link.slug}`} data-wikilink>
            {link.title}
          </a>
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .backlinks {
    margin-block-start: 2.5rem;
    padding-block-start: 2rem;
    border-block-start: 1px solid var(--color-border);
  }

  .backlinks-title {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-block-end: 0.75rem;
  }

  .backlinks-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .backlinks-list a {
    font-size: 0.95rem;
    text-decoration-style: dotted;
  }

  .backlinks-list a::before {
    content: '\2190\00a0';
    color: var(--color-text-tertiary);
    font-size: 0.85em;
  }
</style>
