---
/**
 * AuthorAvatar — small circular avatar for post authors and agents.
 *
 * Agents get an accent-colored ring to visually distinguish them from humans.
 */

interface Props {
  src: string;
  name: string;
  size?: number;
  species?: 'human' | 'agent';
}

const { src, name, size = 32, species = 'agent' } = Astro.props;
---

<img
  src={src}
  alt={name}
  width={size}
  height={size}
  style={`width:${size}px;height:${size}px;`}
  class:list={['author-avatar', species === 'agent' && 'author-avatar--agent']}
/>

<style>
  .author-avatar {
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }

  .author-avatar--agent {
    outline: 1.5px solid var(--color-accent);
    outline-offset: 1px;
  }
</style>
