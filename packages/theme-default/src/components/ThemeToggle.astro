---
/**
 * ThemeToggle — switches between light and dark theme.
 *
 * Both icons occupy the same grid cell. The active one fades/rotates in,
 * the other fades/rotates out. No layout shift. Same pixel.
 */
---

<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
  <span class="theme-toggle-icon-wrapper">
    <svg class="theme-toggle-icon theme-toggle-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
    <svg class="theme-toggle-icon theme-toggle-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </span>
</button>

<style>
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--color-accent);
  }

  /* Both icons stack in the same 18x18 grid cell */
  .theme-toggle-icon-wrapper {
    display: grid;
    width: 18px;
    height: 18px;
  }

  .theme-toggle-icon {
    grid-area: 1 / 1;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  /* Light mode (default): show moon, hide sun */
  .theme-toggle-sun {
    opacity: 0;
    transform: rotate(-45deg) scale(0.8);
  }
  .theme-toggle-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* Dark mode: show sun, hide moon */
  :global([data-theme="dark"]) .theme-toggle-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  :global([data-theme="dark"]) .theme-toggle-moon {
    opacity: 0;
    transform: rotate(45deg) scale(0.8);
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme="light"])) .theme-toggle-sun {
      opacity: 1;
      transform: rotate(0deg) scale(1);
    }
    :global(:root:not([data-theme="light"])) .theme-toggle-moon {
      opacity: 0;
      transform: rotate(45deg) scale(0.8);
    }
  }
</style>

<script is:inline>
  document.getElementById('theme-toggle').addEventListener('click', function() {
    var html = document.documentElement;
    var current = html.getAttribute('data-theme');
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    var isDark = current === 'dark' || (!current && prefersDark);
    var next = isDark ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
