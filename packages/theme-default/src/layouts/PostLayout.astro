---
/**
 * PostLayout — Layout for individual blog posts.
 *
 * Renders: post header (title, metadata), content with prose styling,
 * tag list, and backlinks panel. Ships zero JavaScript.
 */
import BaseLayout from './BaseLayout.astro';

interface BacklinkRef {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  date: string;
  description?: string;
  tags?: string[];
  agent?: string | null;
  confidence?: number | null;
  minutesRead?: number | null;
  backlinks?: BacklinkRef[];
  ogImage?: string;
}

const {
  title,
  date,
  description,
  tags = [],
  agent,
  confidence,
  minutesRead,
  backlinks = [],
  ogImage,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const confidenceLabel = confidence != null
  ? `${Math.round(confidence * 100)}% confidence`
  : null;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>

      <div class="post-meta">
        <time datetime={date}>{formattedDate}</time>
        {minutesRead && (
          <>
            <span class="post-meta-sep" aria-hidden="true">&middot;</span>
            <span>{minutesRead} min read</span>
          </>
        )}
        {agent && (
          <>
            <span class="post-meta-sep" aria-hidden="true">&middot;</span>
            <span class="post-agent">{agent}</span>
          </>
        )}
        {confidenceLabel && (
          <>
            <span class="post-meta-sep" aria-hidden="true">&middot;</span>
            <span class="post-confidence">{confidenceLabel}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="post-tags">
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="post-tag">
            {tag}
          </a>
        ))}
      </footer>
    )}

    {backlinks.length > 0 && (
      <aside class="post-backlinks" aria-label="Backlinks">
        <h2 class="post-backlinks-title">Linked from</h2>
        <ul class="post-backlinks-list">
          {backlinks.map((link) => (
            <li>
              <a href={`/posts/${link.slug}`} data-wikilink>
                {link.title}
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </article>

  <style>
    .post {
      max-width: 42rem;
      margin-inline: auto;
    }

    /* ─── Header ─── */

    .post-header {
      margin-block-end: clamp(2rem, 5vw, 3rem);
    }

    .post-title {
      font-size: clamp(1.875rem, 1.5rem + 1.5vw, 2.75rem);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.025em;
      margin-block-end: 0.75rem;
    }

    .post-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0;
      font-family: var(--font-heading);
      font-size: 0.875rem;
      color: var(--color-text-secondary);
    }

    .post-meta-sep {
      margin-inline: 0.5rem;
      color: var(--color-text-tertiary);
    }

    .post-agent {
      font-weight: 500;
    }

    .post-confidence {
      font-variant-numeric: tabular-nums;
    }

    /* ─── Content ─── */

    .post-content {
      margin-block-end: 2.5rem;
    }

    /* ─── Tags ─── */

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding-block-start: 1.5rem;
      border-block-start: 1px solid var(--color-border);
    }

    .post-tag {
      display: inline-block;
      padding: 0.2em 0.7em;
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--color-text-secondary);
      background-color: var(--color-surface);
      border-radius: 3px;
      text-decoration: none;
      letter-spacing: 0.01em;
      transition: color 0.15s ease, background-color 0.15s ease;
    }

    .post-tag:hover {
      color: var(--color-accent);
      background-color: var(--color-code-bg);
    }

    /* ─── Backlinks ─── */

    .post-backlinks {
      margin-block-start: 2.5rem;
      padding-block-start: 2rem;
      border-block-start: 1px solid var(--color-border);
    }

    .post-backlinks-title {
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-tertiary);
      margin-block-end: 0.75rem;
    }

    .post-backlinks-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .post-backlinks-list a {
      font-size: 0.95rem;
      text-decoration-style: dotted;
    }

    .post-backlinks-list a::before {
      content: '\2190\00a0';
      color: var(--color-text-tertiary);
      font-size: 0.85em;
    }
  </style>
</BaseLayout>
