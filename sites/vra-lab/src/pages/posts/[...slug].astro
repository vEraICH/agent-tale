---
import { getCollection, render } from 'astro:content';
import PostLayout from '@agent-tale/theme-vra-lab/layouts/PostLayout.astro';
import LessonLayout from '@agent-tale/theme-vra-lab/layouts/LessonLayout.astro';
import { getBacklinks, getRelated, nodes as graphNodes, edges as graphEdges } from 'agent-tale:graph';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const backlinks = getBacklinks(post.id);

// Related posts by graph proximity (vra-12)
const nodeMap = new Map(graphNodes.map((n) => [n.slug, n]));
const relatedPosts = getRelated(post.id).map((ref) => {
  const node = nodeMap.get(ref.slug);
  return {
    slug: ref.slug,
    title: ref.title,
    tags: node?.tags ?? [],
    date: node?.date ?? null,
    connectionCount: (node?.inDegree ?? 0) + (node?.outDegree ?? 0),
  };
});

const readingTime = (post as any).data?.readingTime?.minutes
  ?? (post.body ? Math.max(1, Math.ceil(post.body.split(/\s+/).length / 238)) : null);

const isLesson = post.data.type === 'lesson';

// Series nav (vra-14)
const seriesName = post.data.series;
const allPosts = await getCollection('posts');
const seriesPosts = seriesName
  ? allPosts
      .filter((p) => p.data.series === seriesName && !p.data.draft)
      .map((p) => ({
        slug: p.id,
        title: p.data.title,
        seriesOrder: p.data.seriesOrder ?? 0,
        isCurrent: p.id === post.id,
      }))
  : [];
---

{isLesson ? (
  <LessonLayout
    title={post.data.title}
    date={post.data.date.toISOString()}
    description={post.data.description}
    tags={post.data.tags}
    agent={post.data.agent}
    confidence={post.data.confidence}
    minutesRead={readingTime}
    mistake={post.data.mistake}
    insight={post.data.insight}
    applies_to={post.data.applies_to}
    backlinks={backlinks}
  >
    <Content />
  </LessonLayout>
) : (
  <PostLayout
    title={post.data.title}
    date={post.data.date.toISOString()}
    description={post.data.description}
    tags={post.data.tags}
    agent={post.data.agent}
    author={post.data.author}
    confidence={post.data.confidence}
    minutesRead={readingTime}
    backlinks={backlinks}
    headings={headings}
    ogImage={`${Astro.site ?? ''}og/${post.id}.png`}
    slug={post.id}
    graphNodes={graphNodes}
    graphEdges={graphEdges}
    relatedPosts={relatedPosts}
    seriesName={seriesName}
    seriesPosts={seriesPosts}
  >
    <Content />
  </PostLayout>
)}
