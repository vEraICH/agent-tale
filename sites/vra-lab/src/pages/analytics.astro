---
export const prerender = false;

import BaseLayout from '@agent-tale/theme-vra-lab/layouts/BaseLayout.astro';
import { nodes as rawNodes, edges as rawEdges } from 'agent-tale:graph';
import { computeGraphMetrics, getStoreIfExists } from '@agent-tale/analytic';
import { join } from 'node:path';

// ── Human metrics (live from SQLite, null if no data yet) ──
const DB_PATH = process.env.ANALYTICS_DB_PATH ?? join(process.cwd(), 'data', 'analytics.db');
const store = getStoreIfExists(DB_PATH);

const humanMetrics = store
  ? {
      totalViews:    store.getTotalViews(),
      uniqueSessions: store.getUniqueSessionCount(),
      topPosts:      store.getTopPosts(10),
      topEdges:      store.getTopEdges(5),
      dailyViews:    store.getDailyViews(14),
    }
  : null;

// Build a minimal GraphInput from the virtual module data
const nodeMap = new Map(
  rawNodes.map(n => [n.slug, { slug: n.slug, title: n.title, inDegree: n.inDegree, outDegree: n.outDegree }]),
);
const metrics = computeGraphMetrics({ nodes: nodeMap, edges: rawEdges });
const builtAt = new Date().toISOString().split('T')[0];

// ── Arc gauge geometry (semicircle: center 120,105, radius 90) ──
const arcR = 90;
const arcTotal = Math.PI * arcR;                          // ≈ 282.74
const arcFilled = metrics.connectivity * arcTotal;
const arcStroke = 10;

// ── Connectivity status ──
function connStatus(c: number): { label: string; cssColor: string } {
  if (c >= 0.75) return { label: 'Healthy',    cssColor: 'var(--color-accent)' };
  if (c >= 0.40) return { label: 'Fragmented', cssColor: 'oklch(0.72 0.12 55)' };
  return              { label: 'Sparse',      cssColor: 'oklch(0.62 0.10 22)' };
}
const status = connStatus(metrics.connectivity);

// ── Score normalisers ──
const maxPagerank    = metrics.topCentralNodes[0]?.score ?? 1;
const maxBetweenness = metrics.bridgeNodes[0]?.score ?? 1;

function pct(n: number, max: number) {
  return max === 0 ? 0 : Math.round((n / max) * 100);
}

function fmt(n: number): string {
  if (n === 0) return '0';
  if (n < 0.001) return n.toExponential(2);
  return n.toFixed(4).replace(/0+$/, '').replace(/\.$/, '');
}

// ── Edge inventory with bidirectionality ──
const edgeSet = new Set(rawEdges.map(e => `${e.source}→${e.target}`));
type EnrichedEdge = { source: string; target: string; bidirectional: boolean };
const enrichedEdges: EnrichedEdge[] = rawEdges.map(e => ({
  source: e.source,
  target: e.target,
  bidirectional: edgeSet.has(`${e.target}→${e.source}`),
}));
// Show each pair once: for bidirectional A⇄B, keep the one where source < target
const displayEdges = enrichedEdges.filter(e =>
  !e.bidirectional || e.source < e.target,
).sort((a, b) => a.source.localeCompare(b.source));
const biCount  = displayEdges.filter(e => e.bidirectional).length;
const uniCount = displayEdges.filter(e => !e.bidirectional).length;

// ── Health grade ──
// Simple composite: connectivity (50%) + low orphan rate (30%) + diameter reasonable (20%)
const orphanScore      = 1 - metrics.orphanRate;
const diameterScore    = metrics.diameter == null ? 0.5 : Math.max(0, 1 - (metrics.diameter - 2) / 10);
const compositeHealth  = metrics.connectivity * 0.5 + orphanScore * 0.3 + diameterScore * 0.2;
const healthGrade = compositeHealth >= 0.85 ? 'A' : compositeHealth >= 0.70 ? 'B' : compositeHealth >= 0.50 ? 'C' : 'D';
---

<BaseLayout
  title="Analytics"
  description="Build-time graph health dashboard for the VRA Lab content graph."
>
  <div class="analytics">

    <!-- ── Page header ── -->
    <header class="an-header">
      <div class="an-header-left">
        <p class="an-eyebrow">Graph Health</p>
        <h1 class="an-title">Analytics</h1>
        <p class="an-subtitle">Build-time snapshot of the VRA Lab content graph.</p>
      </div>
      <div class="an-header-right">
        <div class="an-grade" style={`color: ${status.cssColor}; border-color: ${status.cssColor};`}>
          <span class="an-grade-letter">{healthGrade}</span>
          <span class="an-grade-label">Health</span>
        </div>
        <p class="an-built-at">Computed {builtAt}</p>
      </div>
    </header>

    <!-- ── Hero: Connectivity gauge ── -->
    <section class="an-gauge-section" aria-label="Connectivity gauge">
      <div class="an-gauge-card">
        <div class="an-gauge-wrap">
          <svg
            viewBox="0 0 240 115"
            width="240"
            height="115"
            aria-hidden="true"
            class="an-gauge-svg"
          >
            <!-- Background track -->
            <path
              d="M 30 105 A 90 90 0 0 1 210 105"
              fill="none"
              stroke="var(--color-border-strong)"
              stroke-width={arcStroke}
              stroke-linecap="round"
            />
            <!-- Filled arc -->
            <path
              d="M 30 105 A 90 90 0 0 1 210 105"
              fill="none"
              stroke={status.cssColor}
              stroke-width={arcStroke}
              stroke-linecap="round"
              stroke-dasharray={`${arcFilled} ${arcTotal}`}
              stroke-dashoffset="0"
            />
            <!-- Tick marks at 25%, 50%, 75% -->
            {[0.25, 0.5, 0.75].map(t => {
              const angle = Math.PI * t; // 0 = left, π = right along the arc
              const x = 120 - Math.cos(angle) * 90;
              const y = 105 - Math.sin(angle) * 90;
              const ix = 120 - Math.cos(angle) * 76;
              const iy = 105 - Math.sin(angle) * 76;
              return (
                <line
                  x1={x} y1={y} x2={ix} y2={iy}
                  stroke="var(--color-bg)"
                  stroke-width="1.5"
                  opacity="0.6"
                />
              );
            })}
            <!-- Labels: 0%, 50%, 100% -->
            <text x="22" y="117" text-anchor="middle" class="gauge-label">0%</text>
            <text x="120" y="10" text-anchor="middle" class="gauge-label">{Math.round(metrics.connectivity * 50)}%</text>
            <text x="218" y="117" text-anchor="middle" class="gauge-label">100%</text>
          </svg>

          <div class="an-gauge-center">
            <span class="an-gauge-pct">{Math.round(metrics.connectivity * 100)}%</span>
            <span class="an-gauge-name">connected</span>
          </div>
        </div>

        <div class="an-gauge-meta">
          <span class="an-status-badge" style={`color: ${status.cssColor}; border-color: color-mix(in oklch, ${status.cssColor} 35%, transparent);`}>
            {status.label}
          </span>
          <span class="an-gauge-desc">
            {metrics.nodeCount === 0
              ? 'No nodes yet.'
              : `${Math.round(metrics.connectivity * metrics.nodeCount)} of ${metrics.nodeCount} nodes in the largest cluster.`
            }
          </span>
        </div>
      </div>
    </section>

    <!-- ── Metrics grid ── -->
    <section class="an-metrics" aria-label="Key metrics">
      <div class="an-metric-card">
        <span class="an-metric-val">{metrics.nodeCount}</span>
        <span class="an-metric-label">Nodes</span>
        <span class="an-metric-hint">posts in the graph</span>
      </div>
      <div class="an-metric-card">
        <span class="an-metric-val">{metrics.edgeCount}</span>
        <span class="an-metric-label">Edges</span>
        <span class="an-metric-hint">wikilink connections</span>
      </div>
      <div class="an-metric-card">
        <span class="an-metric-val">{metrics.clusterCount}</span>
        <span class="an-metric-label">Clusters</span>
        <span class="an-metric-hint">Louvain communities</span>
      </div>
      <div class="an-metric-card" class:list={[{ 'an-metric-warn': metrics.orphanRate > 0.3 }]}>
        <span class="an-metric-val">{metrics.orphanCount}</span>
        <span class="an-metric-label">Orphans</span>
        <span class="an-metric-hint">{metrics.nodeCount > 0 ? `${Math.round(metrics.orphanRate * 100)}% have no inbound links` : 'no nodes'}</span>
      </div>
      <div class="an-metric-card">
        <span class="an-metric-val">{metrics.diameter ?? '—'}</span>
        <span class="an-metric-label">Diameter</span>
        <span class="an-metric-hint">longest shortest path</span>
      </div>
    </section>

    <!-- ── Two-column: hubs + bridges ── -->
    <div class="an-two-col">

      <!-- Hubs (PageRank) -->
      <section class="an-ranked" aria-labelledby="hubs-title">
        <h2 class="an-section-title" id="hubs-title">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="an-section-icon">
            <circle cx="8" cy="8" r="3.5" stroke="currentColor" stroke-width="1.5"/>
            <line x1="8" y1="0.5" x2="8" y2="4" stroke="currentColor" stroke-width="1.5"/>
            <line x1="8" y1="12" x2="8" y2="15.5" stroke="currentColor" stroke-width="1.5"/>
            <line x1="0.5" y1="8" x2="4" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <line x1="12" y1="8" x2="15.5" y2="8" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Hubs
          <span class="an-section-sub">by PageRank</span>
        </h2>
        {metrics.topCentralNodes.length === 0
          ? <p class="an-empty">No nodes yet.</p>
          : (
            <ol class="an-ranked-list">
              {metrics.topCentralNodes.map((node, i) => (
                <li class="an-ranked-item">
                  <span class="an-ranked-pos">{String(i + 1).padStart(2, '0')}</span>
                  <div class="an-ranked-body">
                    <a href={`/posts/${node.slug}`} class="an-ranked-title">{node.title}</a>
                    <div class="an-bar-row">
                      <div class="an-bar-track">
                        <div class="an-bar-fill" style={`width: ${pct(node.score, maxPagerank)}%`}></div>
                      </div>
                      <span class="an-bar-score">{fmt(node.score)}</span>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          )
        }
      </section>

      <!-- Bridges (Betweenness) -->
      <section class="an-ranked" aria-labelledby="bridges-title">
        <h2 class="an-section-title" id="bridges-title">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="an-section-icon">
            <circle cx="2.5" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="13.5" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
            <line x1="4.5" y1="8" x2="6" y2="8" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="8" x2="11.5" y2="8" stroke="currentColor" stroke-width="1.5"/>
          </svg>
          Bridges
          <span class="an-section-sub">by betweenness</span>
        </h2>
        {metrics.bridgeNodes.length === 0
          ? <p class="an-empty">Not enough edges to compute.</p>
          : (
            <ol class="an-ranked-list">
              {metrics.bridgeNodes.map((node, i) => (
                <li class="an-ranked-item">
                  <span class="an-ranked-pos">{String(i + 1).padStart(2, '0')}</span>
                  <div class="an-ranked-body">
                    <a href={`/posts/${node.slug}`} class="an-ranked-title">{node.title}</a>
                    <div class="an-bar-row">
                      <div class="an-bar-track">
                        <div class="an-bar-fill an-bar-fill--bridge" style={`width: ${pct(node.score, maxBetweenness)}%`}></div>
                      </div>
                      <span class="an-bar-score">{fmt(node.score)}</span>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          )
        }
      </section>

    </div>

    <!-- ── Edge inventory ── -->
    <section class="an-edges" aria-labelledby="edges-title">
      <h2 class="an-section-title" id="edges-title">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="an-section-icon">
          <circle cx="3" cy="8" r="2.5" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="13" cy="8" r="2.5" stroke="currentColor" stroke-width="1.4"/>
          <line x1="5.5" y1="8" x2="10.5" y2="8" stroke="currentColor" stroke-width="1.4"/>
          <polyline points="8.5,5.5 10.5,8 8.5,10.5" stroke="currentColor" stroke-width="1.4" fill="none"/>
        </svg>
        Edges
        <span class="an-section-sub">{displayEdges.length} connections · {biCount} mutual · {uniCount} one-way</span>
      </h2>
      {displayEdges.length === 0
        ? <p class="an-empty">No wikilink edges found yet.</p>
        : (
          <div class="an-edge-table-wrap">
            <table class="an-edge-table">
              <thead>
                <tr>
                  <th>Source</th>
                  <th></th>
                  <th>Target</th>
                  <th class="an-edge-dir-col">Direction</th>
                </tr>
              </thead>
              <tbody>
                {displayEdges.map(e => (
                  <tr>
                    <td>
                      <a href={`/posts/${e.source}`} class="an-edge-link">{nodeMap.get(e.source)?.title ?? e.source}</a>
                    </td>
                    <td class="an-edge-arrow" aria-hidden="true">{e.bidirectional ? '⇄' : '→'}</td>
                    <td>
                      <a href={`/posts/${e.target}`} class="an-edge-link">{nodeMap.get(e.target)?.title ?? e.target}</a>
                    </td>
                    <td class="an-edge-dir-col">
                      <span class={`an-edge-badge ${e.bidirectional ? 'an-edge-badge--mutual' : 'an-edge-badge--oneway'}`}>
                        {e.bidirectional ? 'mutual' : 'one-way'}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </section>

    <!-- ── Human metrics ── -->
    <section class="an-human" aria-labelledby="human-title">
      <h2 class="an-section-title" id="human-title">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="an-section-icon">
          <circle cx="8" cy="5" r="2.5" stroke="currentColor" stroke-width="1.4"/>
          <path d="M2 14c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
        Visitors
        <span class="an-section-sub">live · human traffic</span>
      </h2>

      {!humanMetrics ? (
        <div class="an-human-empty">
          <p class="an-human-empty-msg">No visitor data yet.</p>
          <p class="an-human-empty-hint">
            <code>{'<AnalyticTracker />'}</code> is active on all post pages.
            Visit a post to record your first event.
          </p>
        </div>
      ) : (
        <div class="an-human-content">

          <!-- Summary cards -->
          <div class="an-human-summary">
            <div class="an-human-card">
              <span class="an-metric-val">{humanMetrics.totalViews}</span>
              <span class="an-metric-label">Page Views</span>
              <span class="an-metric-hint">post.read events</span>
            </div>
            <div class="an-human-card">
              <span class="an-metric-val">{humanMetrics.uniqueSessions}</span>
              <span class="an-metric-label">Sessions</span>
              <span class="an-metric-hint">unique fingerprints</span>
            </div>
            <div class="an-human-card">
              <span class="an-metric-val">{humanMetrics.topEdges.reduce((s, e) => s + e.follows, 0)}</span>
              <span class="an-metric-label">Link Clicks</span>
              <span class="an-metric-hint">wikilink.followed events</span>
            </div>
          </div>

          <!-- Daily views sparkline -->
          {humanMetrics.dailyViews.length > 0 && (() => {
            const days = 14;
            // Fill gaps with zero
            const today = new Date();
            const filled: number[] = Array.from({ length: days }, (_, i) => {
              const d = new Date(today);
              d.setDate(d.getDate() - (days - 1 - i));
              const key = d.toISOString().split('T')[0];
              return humanMetrics.dailyViews.find(r => r.day === key)?.count ?? 0;
            });
            const maxVal = Math.max(...filled, 1);
            const barW = 12;
            const gap = 4;
            const chartW = days * (barW + gap) - gap;
            const chartH = 40;
            return (
              <div class="an-sparkline-wrap">
                <span class="an-sparkline-label">Last 14 days</span>
                <svg viewBox={`0 0 ${chartW} ${chartH}`} width={chartW} height={chartH} aria-label="Daily page views" class="an-sparkline">
                  {filled.map((v, i) => {
                    const barH = Math.max(2, Math.round((v / maxVal) * chartH));
                    const x = i * (barW + gap);
                    const y = chartH - barH;
                    return (
                      <rect
                        x={x} y={y} width={barW} height={barH}
                        rx="2"
                        fill={v > 0 ? 'var(--color-accent)' : 'var(--color-border-strong)'}
                        opacity={v > 0 ? 0.8 : 0.4}
                      >
                        <title>{`${v} view${v !== 1 ? 's' : ''}`}</title>
                      </rect>
                    );
                  })}
                </svg>
              </div>
            );
          })()}

          <!-- Top posts table -->
          {humanMetrics.topPosts.length > 0 && (
            <div class="an-human-section">
              <h3 class="an-human-sub">Top Posts</h3>
              <div class="an-edge-table-wrap">
                <table class="an-edge-table">
                  <thead>
                    <tr>
                      <th>#</th>
                      <th>Post</th>
                      <th class="an-num-col">Views</th>
                      <th class="an-num-col">Sessions</th>
                      <th class="an-num-col">Avg Depth</th>
                    </tr>
                  </thead>
                  <tbody>
                    {humanMetrics.topPosts.map((p, i) => (
                      <tr>
                        <td class="an-rank-col">{i + 1}</td>
                        <td>
                          <a href={`/posts/${p.slug}`} class="an-edge-link">
                            {nodeMap.get(p.slug)?.title ?? p.slug}
                          </a>
                        </td>
                        <td class="an-num-col">{p.views}</td>
                        <td class="an-num-col">{p.unique_sessions}</td>
                        <td class="an-num-col">
                          {p.avg_depth != null ? `${Math.round(p.avg_depth)}%` : '—'}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <!-- Top wikilink edges clicked -->
          {humanMetrics.topEdges.length > 0 && (
            <div class="an-human-section">
              <h3 class="an-human-sub">Most-Followed Links</h3>
              <ol class="an-ranked-list">
                {humanMetrics.topEdges.map((e, i) => (
                  <li class="an-ranked-item">
                    <span class="an-ranked-pos">{String(i + 1).padStart(2, '0')}</span>
                    <div class="an-ranked-body">
                      <span class="an-ranked-title" style="cursor:default">
                        {nodeMap.get(e.source)?.title ?? e.source}
                        <span style="opacity:0.4;margin-inline:0.3em">→</span>
                        {nodeMap.get(e.target)?.title ?? e.target}
                      </span>
                      <div class="an-bar-row">
                        <div class="an-bar-track">
                          <div class="an-bar-fill" style={`width:${Math.round((e.follows / (humanMetrics.topEdges[0]?.follows ?? 1)) * 100)}%`}></div>
                        </div>
                        <span class="an-bar-score">{e.follows} click{e.follows !== 1 ? 's' : ''}</span>
                      </div>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          )}

        </div>
      )}
    </section>

    <!-- ── Footer note ── -->
    <footer class="an-footer-note">
      <p>
        Metrics computed at build time using
        <a href="https://graphology.github.io/" class="an-footer-link">graphology</a>
        — PageRank, Louvain clustering, and betweenness centrality on the wikilink graph.
        No JavaScript required.
      </p>
    </footer>

  </div>

  <style>
    .analytics {
      max-width: 60rem;
      margin-inline: auto;
    }

    /* ── Page header ── */
    .an-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      margin-block-end: clamp(2rem, 5vw, 3rem);
      flex-wrap: wrap;
    }

    .an-eyebrow {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-accent);
      margin: 0 0 0.5rem;
    }

    .an-title {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 1.6rem + 1.6vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      margin: 0 0 0.5rem;
      line-height: 1.1;
    }

    .an-subtitle {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      color: var(--color-text-tertiary);
      margin: 0;
    }

    .an-header-right {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.5rem;
      flex-shrink: 0;
    }

    .an-grade {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      width: 64px;
      height: 64px;
      border: 2px solid;
      border-radius: 8px;
      gap: 0.1rem;
    }

    .an-grade-letter {
      font-family: var(--font-heading);
      font-size: 1.75rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .an-grade-label {
      font-family: var(--font-heading);
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.7;
    }

    .an-built-at {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--color-text-tertiary);
      margin: 0;
      font-variant-numeric: tabular-nums;
    }

    /* ── Connectivity gauge ── */
    .an-gauge-section {
      margin-block-end: clamp(2rem, 4vw, 3rem);
    }

    .an-gauge-card {
      display: flex;
      align-items: center;
      gap: 2rem;
      padding: 1.75rem 2rem;
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      flex-wrap: wrap;
    }

    .an-gauge-wrap {
      position: relative;
      flex-shrink: 0;
    }

    .an-gauge-svg {
      display: block;
      overflow: visible;
    }

    .gauge-label {
      font-family: var(--font-mono);
      font-size: 9px;
      fill: var(--color-text-tertiary);
      font-variant-numeric: tabular-nums;
    }

    .an-gauge-center {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      text-align: center;
      pointer-events: none;
      padding-block-end: 0.25rem;
    }

    .an-gauge-pct {
      display: block;
      font-family: var(--font-heading);
      font-size: clamp(2rem, 1.6rem + 1vw, 2.75rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      color: var(--color-text);
      font-variant-numeric: tabular-nums;
    }

    .an-gauge-name {
      display: block;
      font-family: var(--font-heading);
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-tertiary);
      margin-block-start: 0.2rem;
    }

    .an-gauge-meta {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .an-status-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.25em 0.7em;
      font-family: var(--font-heading);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border: 1px solid;
      border-radius: 4px;
      width: fit-content;
    }

    .an-gauge-desc {
      font-family: var(--font-heading);
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      max-width: 28ch;
      line-height: 1.5;
    }

    /* ── Metrics grid ── */
    .an-metrics {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 1px;
      background-color: var(--color-border);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow: hidden;
      margin-block-end: clamp(2rem, 4vw, 3rem);
    }

    .an-metric-card {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 1.25rem 1.5rem;
      background-color: var(--color-bg);
    }

    .an-metric-card.an-metric-warn .an-metric-val {
      color: oklch(0.72 0.12 55);
    }

    .an-metric-val {
      font-family: var(--font-heading);
      font-size: clamp(1.75rem, 1.4rem + 0.8vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1;
      color: var(--color-text);
      font-variant-numeric: tabular-nums;
    }

    .an-metric-label {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      letter-spacing: 0.02em;
    }

    .an-metric-hint {
      font-family: var(--font-heading);
      font-size: 0.72rem;
      color: var(--color-text-tertiary);
      letter-spacing: 0.01em;
      line-height: 1.4;
    }

    /* ── Two-column layout ── */
    .an-two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-block-end: clamp(2rem, 4vw, 3rem);
    }

    /* ── Shared section styles ── */
    .an-section-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-tertiary);
      margin-block-end: 1rem;
      padding-block-end: 0.75rem;
      border-block-end: 1px solid var(--color-border);
    }

    .an-section-icon {
      flex-shrink: 0;
      opacity: 0.6;
    }

    .an-section-sub {
      font-weight: 400;
      letter-spacing: 0.02em;
      text-transform: none;
      color: var(--color-text-tertiary);
      opacity: 0.7;
    }

    .an-empty {
      font-family: var(--font-heading);
      font-size: 0.875rem;
      color: var(--color-text-tertiary);
      margin: 0;
    }

    /* ── Ranked node lists ── */
    .an-ranked {
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      overflow: hidden;
      min-width: 0;
    }

    .an-ranked-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .an-ranked-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .an-ranked-pos {
      font-family: var(--font-mono);
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--color-text-tertiary);
      padding-block-start: 0.1rem;
      flex-shrink: 0;
      font-variant-numeric: tabular-nums;
      min-width: 1.6rem;
    }

    .an-ranked-body {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .an-ranked-title {
      font-family: var(--font-heading);
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--color-text-secondary);
      text-decoration: none;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.15s ease;
      line-height: 1.3;
    }

    .an-ranked-title:hover {
      color: var(--color-accent);
    }

    .an-bar-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .an-bar-track {
      flex: 1;
      height: 3px;
      background-color: var(--color-border-strong);
      border-radius: 2px;
      overflow: hidden;
    }

    .an-bar-fill {
      height: 100%;
      background-color: var(--color-accent);
      border-radius: 2px;
      transition: width 0.3s ease;
    }

    .an-bar-fill--bridge {
      background-color: oklch(0.65 0.14 220);
    }

    [data-theme="light"] .an-bar-fill--bridge {
      background-color: oklch(0.48 0.18 220);
    }

    .an-bar-score {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--color-text-tertiary);
      flex-shrink: 0;
      font-variant-numeric: tabular-nums;
      min-width: 2.5rem;
      text-align: right;
    }

    /* ── Edge inventory ── */
    .an-edges {
      margin-block-end: clamp(2rem, 4vw, 3rem);
    }

    .an-edge-table-wrap {
      overflow-x: auto;
      border: 1px solid var(--color-border);
      border-radius: 8px;
    }

    .an-edge-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-heading);
      font-size: 0.875rem;
    }

    .an-edge-table thead {
      background-color: var(--color-surface);
      border-block-end: 1px solid var(--color-border);
    }

    .an-edge-table th {
      padding: 0.75rem 1rem;
      text-align: left;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-tertiary);
    }

    .an-edge-table td {
      padding: 0.65rem 1rem;
      border-block-end: 1px solid var(--color-border);
      color: var(--color-text-secondary);
      vertical-align: middle;
    }

    .an-edge-table tbody tr:last-child td {
      border-block-end: none;
    }

    .an-edge-table tbody tr:hover td {
      background-color: var(--color-surface);
    }

    .an-edge-link {
      color: var(--color-text-secondary);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .an-edge-link:hover {
      color: var(--color-accent);
    }

    .an-edge-arrow {
      text-align: center;
      color: var(--color-text-tertiary);
      font-size: 0.9rem;
      width: 2rem;
    }

    .an-edge-dir-col {
      width: 6rem;
    }

    .an-edge-badge {
      display: inline-block;
      padding: 0.15em 0.5em;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      border-radius: 3px;
    }

    .an-edge-badge--mutual {
      background-color: color-mix(in oklch, var(--color-accent) 15%, transparent);
      color: var(--color-accent);
    }

    .an-edge-badge--oneway {
      background-color: var(--color-surface);
      color: var(--color-text-tertiary);
      border: 1px solid var(--color-border);
    }

    /* ── Footer note ── */
    .an-footer-note {
      padding-block: 1.5rem;
      border-block-start: 1px solid var(--color-border);
    }

    .an-footer-note p {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      color: var(--color-text-tertiary);
      margin: 0;
      line-height: 1.6;
    }

    .an-footer-link {
      color: var(--color-text-secondary);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .an-footer-link:hover {
      color: var(--color-accent);
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .an-metrics {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 680px) {
      .an-two-col {
        grid-template-columns: 1fr;
      }

      .an-metrics {
        grid-template-columns: repeat(2, 1fr);
      }

      .an-gauge-card {
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .an-gauge-desc {
        max-width: none;
      }

      .an-gauge-meta {
        align-items: center;
      }
    }

    @media (max-width: 400px) {
      .an-metrics {
        grid-template-columns: 1fr 1fr;
      }
    }

    /* ── Human metrics section ── */
    .an-human {
      margin-block-end: clamp(2rem, 4vw, 3rem);
    }

    .an-human-empty {
      padding: 2rem;
      border: 1px dashed var(--color-border-strong);
      border-radius: 8px;
      text-align: center;
    }

    .an-human-empty-msg {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      margin: 0 0 0.5rem;
    }

    .an-human-empty-hint {
      font-family: var(--font-heading);
      font-size: 0.85rem;
      color: var(--color-text-tertiary);
      margin: 0;
    }

    .an-human-empty-hint code {
      font-family: var(--font-mono);
      font-size: 0.8em;
      color: var(--color-accent);
      background: color-mix(in oklch, var(--color-accent) 10%, transparent);
      padding: 0.1em 0.4em;
      border-radius: 3px;
    }

    .an-human-content {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    .an-human-summary {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background-color: var(--color-border);
      border: 1px solid var(--color-border);
      border-radius: 8px;
      overflow: hidden;
    }

    .an-human-card {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding: 1.25rem 1.5rem;
      background-color: var(--color-bg);
    }

    .an-sparkline-wrap {
      display: flex;
      align-items: flex-end;
      gap: 1rem;
    }

    .an-sparkline-label {
      font-family: var(--font-heading);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-tertiary);
      white-space: nowrap;
    }

    .an-sparkline {
      display: block;
      overflow: visible;
    }

    .an-human-section {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .an-human-sub {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-text-tertiary);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin: 0;
    }

    .an-num-col {
      text-align: right;
      font-variant-numeric: tabular-nums;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      white-space: nowrap;
    }

    .an-rank-col {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--color-text-tertiary);
      text-align: center;
      width: 2rem;
    }

    @media (max-width: 480px) {
      .an-human-summary {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
