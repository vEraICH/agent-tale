---
import BaseLayout from '@agent-tale/theme-vra-lab/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <div class="not-found">
    <p class="not-found-label">404</p>
    <h1 class="not-found-title">This node doesn't exist yet.</h1>
    <p class="not-found-desc">The tale you're looking for isn't in the graph. It may have moved, or it may not have been written yet.</p>
    <nav class="not-found-nav">
      <a href="/">Back to all tales</a>
      <span class="sep" aria-hidden="true">&middot;</span>
      <a href="/graph">Explore the graph</a>
    </nav>
  </div>

  <style>
    .not-found {
      max-width: 36rem;
      margin-inline: auto;
      padding-block: clamp(4rem, 12vw, 8rem);
      text-align: center;
    }

    .not-found-label {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      color: var(--color-text-tertiary);
      margin: 0 0 1rem;
    }

    .not-found-title {
      font-size: clamp(1.5rem, 1.2rem + 1.2vw, 2rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin: 0 0 1rem;
    }

    .not-found-desc {
      font-family: var(--font-prose, var(--font-body));
      font-size: 1rem;
      line-height: 1.7;
      color: var(--color-text-secondary);
      margin: 0 0 2rem;
    }

    .not-found-nav {
      font-family: var(--font-heading);
      font-size: 0.875rem;
      font-weight: 500;
    }

    .not-found-nav a {
      color: var(--color-accent);
      text-decoration: none;
      transition: color 0.15s ease;
    }

    .not-found-nav a:hover {
      color: var(--color-accent-hover);
    }

    .not-found-nav .sep {
      margin-inline: 0.5rem;
      color: var(--color-text-tertiary);
    }
  </style>
</BaseLayout>
