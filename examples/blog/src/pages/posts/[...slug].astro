---
/**
 * Individual post page — renders markdown content with PostLayout.
 *
 * Uses Astro content collections for markdown rendering,
 * and the graph virtual module for backlinks.
 */
import { getCollection, render } from 'astro:content';
import PostLayout from '@agent-tale/theme-default/layouts/PostLayout.astro';
import { getBacklinks } from 'agent-tale:graph';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const backlinks = getBacklinks(post.id);

const readingTime = (post as any).data?.readingTime?.minutes
  ?? (post.body ? Math.max(1, Math.ceil(post.body.split(/\s+/).length / 238)) : null);
---

<PostLayout
  title={post.data.title}
  date={post.data.date.toISOString()}
  description={post.data.description}
  tags={post.data.tags}
  agent={post.data.agent}
  confidence={post.data.confidence}
  minutesRead={readingTime}
  backlinks={backlinks}
>
  <Content />
</PostLayout>
