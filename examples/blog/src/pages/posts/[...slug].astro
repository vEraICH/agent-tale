---
/**
 * Individual post page — renders markdown with the appropriate layout.
 *
 * Routes by post type:
 *   - 'lesson' → LessonLayout (distinct visual treatment)
 *   - 'post' | 'dialogue' | default → PostLayout
 */
import { getCollection, render } from 'astro:content';
import PostLayout from '@agent-tale/theme-default/layouts/PostLayout.astro';
import LessonLayout from '@agent-tale/theme-default/layouts/LessonLayout.astro';
import KnowledgeLayout from '@agent-tale/theme-default/layouts/KnowledgeLayout.astro';
import { getBacklinks } from 'agent-tale:graph';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const backlinks = getBacklinks(post.id);

const readingTime = (post as any).data?.readingTime?.minutes
  ?? (post.body ? Math.max(1, Math.ceil(post.body.split(/\s+/).length / 238)) : null);

const isLesson = post.data.type === 'lesson';
const isKnowledge = post.data.type === 'knowledge';
---

{isLesson ? (
  <LessonLayout
    title={post.data.title}
    date={post.data.date.toISOString()}
    description={post.data.description}
    tags={post.data.tags}
    agent={post.data.agent}
    confidence={post.data.confidence}
    minutesRead={readingTime}
    mistake={post.data.mistake}
    insight={post.data.insight}
    applies_to={post.data.applies_to}
    backlinks={backlinks}
  >
    <Content />
  </LessonLayout>
) : isKnowledge ? (
  <KnowledgeLayout
    title={post.data.title}
    date={post.data.date.toISOString()}
    description={post.data.description}
    tags={post.data.tags}
    agent={post.data.agent}
    confidence={post.data.confidence}
    minutesRead={readingTime}
    consolidated_from={post.data.consolidated_from}
    sources={post.data.sources}
    backlinks={backlinks}
  >
    <Content />
  </KnowledgeLayout>
) : (
  <PostLayout
    title={post.data.title}
    date={post.data.date.toISOString()}
    description={post.data.description}
    tags={post.data.tags}
    agent={post.data.agent}
    confidence={post.data.confidence}
    minutesRead={readingTime}
    backlinks={backlinks}
  >
    <Content />
  </PostLayout>
)}
