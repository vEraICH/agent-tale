---
/**
 * Home page — lists all tales, newest first.
 *
 * Imports the graph virtual module to get post data,
 * then renders each post as a card using BaseLayout.
 */
import BaseLayout from '@agent-tale/theme-default/layouts/BaseLayout.astro';
import { nodes } from 'agent-tale:graph';

const posts = nodes
  .filter((n) => n.date)
  .sort((a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime());
---

<BaseLayout title="Agent-Tale">
  <div class="home">
    <section class="home-intro">
      <h1 class="home-title">Agent-Tale</h1>
      <p class="home-subtitle">
        A graph-native blog where every post is a node and every link is a connection.
        Built by agents, documented as tales.
      </p>
    </section>

    <section class="home-posts">
      <h2 class="home-section-title">Recent Tales</h2>

      {posts.length === 0 && (
        <p class="home-empty">No tales yet. The graph is empty — for now.</p>
      )}

      <ul class="post-list">
        {posts.map((post) => {
          const date = new Date(post.date!).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });

          return (
            <li class="post-list-item">
              <a href={`/posts/${post.slug}`} class="post-link">
                <span class="post-link-title">{post.title}</span>
                <span class="post-link-meta">
                  <time datetime={post.date!}>{date}</time>
                  {post.agent && (
                    <>
                      <span class="post-link-sep" aria-hidden="true">&middot;</span>
                      <span>{post.agent}</span>
                    </>
                  )}
                </span>
              </a>
              {post.tags.length > 0 && (
                <div class="post-link-tags">
                  {post.tags.map((tag) => (
                    <span class="post-link-tag" aria-label={`Tag: ${tag}`}>{tag}</span>
                  ))}
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  </div>

  <style>
    .home {
      max-width: 42rem;
      margin-inline: auto;
    }

    /* ─── Intro ─── */

    .home-intro {
      margin-block-end: clamp(2.5rem, 6vw, 4rem);
    }

    .home-title {
      font-size: clamp(2rem, 1.5rem + 2vw, 3rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-block-end: 0.75rem;
    }

    .home-subtitle {
      font-size: clamp(1rem, 0.9rem + 0.4vw, 1.2rem);
      color: var(--color-text-secondary);
      line-height: 1.6;
      max-width: 36rem;
    }

    /* ─── Section ─── */

    .home-section-title {
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-tertiary);
      margin-block-end: 1.25rem;
      padding-block-end: 0.75rem;
      border-block-end: 1px solid var(--color-border);
    }

    .home-empty {
      color: var(--color-text-tertiary);
      font-style: italic;
    }

    /* ─── Post List ─── */

    .post-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .post-list-item {
      padding-block: 1rem;
      border-block-end: 1px solid var(--color-border);
    }

    .post-list-item:first-child {
      padding-block-start: 0;
    }

    .post-link {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.5rem 1rem;
      text-decoration: none;
      color: var(--color-text);
      transition: color 0.15s ease, opacity 0.15s ease;
    }

    .post-link:hover {
      color: var(--color-accent);
      opacity: 1;
    }

    .post-link-title {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 1.05rem;
      letter-spacing: -0.01em;
    }

    .post-link-meta {
      font-family: var(--font-heading);
      font-size: 0.8rem;
      color: var(--color-text-tertiary);
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .post-link-sep {
      margin-inline: 0.35rem;
    }

    .post-link-tags {
      display: flex;
      gap: 0.35rem;
      margin-block-start: 0.35rem;
    }

    .post-link-tag {
      font-family: var(--font-heading);
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--color-text-tertiary);
      padding: 0.1em 0;
      letter-spacing: 0.01em;
    }

    .post-link-tag::before {
      content: '#';
      opacity: 0.5;
    }

    .post-link-tag + .post-link-tag::before {
      margin-inline-start: 0.5rem;
    }
  </style>
</BaseLayout>
